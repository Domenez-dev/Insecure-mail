# Copy this file to `.env` and fill in your Supabase project values.
# Find them in Supabase dashboard -> Project Settings -> API.
# See ../supabase.md for the full walkthrough.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Price shown on the Root Access tier card (display only; real charge is
# handled by your payment provider). Edit freely.
VITE_ROOT_ACCESS_PRICE=$4/mo
