    {
      "parameters": {
        "jsCode": "const WINDOW_DAYS = 3;\nconst cutoff = Date.now() - WINDOW_DAYS * 864e5;\n\nconst clean = (s) =>\n  String(s ?? '').replace(/<[^>]+>/g, ' ').replace(/\\s+/g, ' ').trim();\n\n// Feeds scatter the date across different fields — check the usual suspects.\nconst getWhen = (j) => {\n  const raw = j.isoDate || j.pubDate || j.published || j.date || j.updated || j.created;\n  if (!raw) return null;                 // no date found → keep it, don't guess\n  const t = new Date(raw).getTime();\n  return Number.isFinite(t) ? t : null;\n};\n\nconst seen = new Set();\nconst out = [];\n\nfor (const it of $input.all()) {\n  const j = it.json;\n\n  const when = getWhen(j);\n  if (when !== null && when < cutoff) continue;   // only skip if we KNOW it's old\n\n  const key = clean(j.link || j.guid || j.title).split('?')[0];\n  if (!key || seen.has(key)) continue;            // duplicate → skip\n  seen.add(key);\n\n  out.push({\n    json: {\n      title: clean(j.title),\n      link: j.link || '',\n      date: j.isoDate || j.pubDate || j.published || null,\n      snippet: clean(j.contentSnippet || j.content || j.description).slice(0, 400),\n    },\n  });\n}\n\nout.sort((a, b) => new Date(b.json.date || 0) - new Date(a.json.date || 0));  // newest first\nreturn out;"
      },
