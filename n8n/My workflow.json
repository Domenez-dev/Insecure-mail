    {
      "parameters": {
        "jsCode": "const day = new Date().getDay(); // 0=Sun … 6=Sat\n\nconst EDITIONS = {\n  0: { key: 'radar',    edition: 'Sun · Threat Radar', send_tier: 'root',  audience: 'root', window_days: 3  },\n  2: { key: 'deepdive', edition: 'Tue · Deep Dive',    send_tier: 'root',  audience: 'root', window_days: 21 },\n  4: { key: 'brief',    edition: 'Thu · The Brief',    send_tier: 'recon', audience: 'all',  window_days: 8  },\n};\n\n// Without this, a manual run on Mon/Wed/Fri/Sat returns { json: undefined }.\nconst chosen = EDITIONS[day] ?? EDITIONS[4];\n\nreturn [{ json: { ...chosen, day, is_fallback: !EDITIONS[day] } }];"
      },
